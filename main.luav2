    if isfile and isfile(autoexec_filename) then
        _G.AutoExecute = true
    end
end)

AddToggle(Tab4, "Auto Execute (Xeno)", _G.AutoExecute, function(v)
    _G.AutoExecute = v
    if _G.AutoExecute then
        pcall(function()
            if writefile then
                if makefolder then pcall(function() makefolder("autoexec") end) end
                
                -- Raw GitHub linki veya pastebin linkini buradaki adrese koyabilirsin.
                -- Aşağıdaki hazır string, Xeno her açıldığında ana scripti otomatik çekecektir.
                local scriptRawPayload = [[loadstring(game:HttpGet("https://raw.githubusercontent.com/YazdiginScriptLinkiBuraya", true))()]]
                writefile(autoexec_filename, scriptRawPayload)
            end
        end)
    else
        pcall(function()
            if delfile then 
                delfile(autoexec_filename)
            end
        end)
    end
end)

