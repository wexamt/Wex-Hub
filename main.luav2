end

-- [[ ⌨️ G TUŞU VE KISAYOL BIND SİSTEMLERİ ]] --
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if input.KeyCode == Enum.KeyCode.G then
        MainFrame.Visible = not MainFrame.Visible
    end
    
    if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then
        if input.KeyCode == Enum.KeyCode.R then
            _G.AimbotEnabled = not _G.AimbotEnabled
            if activeToggles["Aimbot Aktif (Sağ Tık)"] then
                activeToggles["Aimbot Aktif (Sağ Tık)"].SetState(_G.AimbotEnabled)
            end
        elseif input.KeyCode == Enum.KeyCode.F then
            _G.ShowFOV = not _G.ShowFOV
            if activeToggles["FOV Çemberini Göster"] then
                activeToggles["FOV Çemberini Göster"].SetState(_G.ShowFOV)
            end
        end
    end
end)


-- [[ 🚀 MOTOR VE FİLTRE SİSTEMLERİ (FIXED TEAM CHECK) ]] --
local function isEnemy(player)
    if not _G.TeamCheck then return true end
    
    -- Kesin ve Stabil Team Kontrolü (Hatalar tamamen giderildi)
    if player and LP and player ~= LP then
        if player.Team ~= LP.Team then
            return true
        elseif player.Team == LP.Team and tostring(player.Team) == "Neutral" then
            -- Eğer Rivals'da herkes tek ise (Neutral durumunda) herkes düşmandır
            return true
        end
    end
    return false
end

local function GetClosestPlayer()
    local target = nil
    local dist = _G.AimbotFOV
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LP and v.Character and v.Character:FindFirstChild(_G.AimPart) then
            if isEnemy(v) then
                local hum = v.Character:FindFirstChildOfClass("Humanoid")
                if hum and hum.Health > 0 then
                    local pos, onScreen = Camera:WorldToViewportPoint(v.Character[_G.AimPart].Position)
                    if onScreen then
                        local magnitude = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
                        if magnitude < dist then
                            target = v
                            dist = magnitude
                        end
                    end
                end
            end
        end
    end
    return target
end

-- [[ 🔄 ANA DÖNGÜ ]] --
local tracers = {}

RunService.RenderStepped:Connect(function()
    FOVCircle.Visible = _G.ShowFOV
    FOVCircle.Radius = _G.AimbotFOV
    FOVCircle.Position = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)

    -- SpinBot
    if _G.SpinBot and LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") then
        LP.Character.HumanoidRootPart.CFrame = LP.Character.HumanoidRootPart.CFrame * CFrame.Angles(0, math.rad(_G.SpinSpeed), 0)
    end

    -- Aimbot
    if _G.AimbotEnabled and UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
        local target = GetClosestPlayer()
        if target and target.Character then
            local targetPos = Camera:WorldToViewportPoint(target.Character[_G.AimPart].Position)
            local mousePos = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
            mousemoverel((targetPos.X - mousePos.X) * _G.AimbotSmoothness, (targetPos.Y - mousePos.Y) * _G.AimbotSmoothness)
        end
    end

    -- Visuals (ESP, HP, Tracers)
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LP then
            local char = v.Character
            if char then
                local isEnem = isEnemy(v)
                
                -- Highlight ESP
                local hl = char:FindFirstChild("WexHL")
                if _G.ESP_Enabled and isEnem then
                    if not hl then
                        hl = Instance.new("Highlight", char)
                        hl.Name = "WexHL"
                        hl.FillTransparency = 0.5
                    end
                    hl.FillColor = _G.ESP_Color
                elseif hl then hl:Destroy() end

                -- HP Tag
                local head = char:FindFirstChild("Head")
                if head then
                    local tag = head:FindFirstChild("WexHP")
                    if _G.ShowHP and isEnem then
                        if not tag then
                            tag = Instance.new("BillboardGui", head)
                            tag.Name = "WexHP"
                            tag.Size = UDim2.new(0, 50, 0, 20)
                            tag.AlwaysOnTop = true
                            tag.ExtentsOffset = Vector3.new(0, 3, 0)
                            local l = Instance.new("TextLabel", tag)
                            l.Name = "Label"
                            l.BackgroundTransparency = 1
                            l.Size = UDim2.new(1, 0, 1, 0)
                            l.Font = Enum.Font.SourceSansBold
                            l.TextSize = 14
                        end
                        local hum = char:FindFirstChildOfClass("Humanoid")
                        if hum then
                            tag.Label.Text = math.floor(hum.Health) .. " HP"
                            tag.Label.TextColor3 = _G.ESP_Color
                        end
                    elseif tag then tag:Destroy() end
                end

                -- Tracers
                local hrp = char:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local pos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
                    if _G.Tracers_Enabled and isEnem and onScreen then
                        local tr = tracers[v] or Drawing.new("Line")
                        tracers[v] = tr
                        tr.Visible = true
                        tr.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                        tr.To = Vector2.new(pos.X, pos.Y)
                        tr.Color = _G.ESP_Color
                    elseif tracers[v] then tracers[v].Visible = false end
                end
            end
        end
    end
end)

-- Jump & TP Bağlantıları
UserInputService.JumpRequest:Connect(function()
    if _G.InfJump and LP.Character and LP.Character:FindFirstChild("Humanoid") then
        LP.Character.Humanoid:ChangeState("Jumping")
    end
end)

UserInputService.InputBegan:Connect(function(input)
    if _G.ClickTP and input.UserInputType == Enum.UserInputType.MouseButton1 and UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then
        local mouse = LP:GetMouse()
        if LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") then
            LP.Character.HumanoidRootPart.CFrame = CFrame.new(mouse.Hit.p + Vector3.new(0, 3, 0))
        end
    end
end)

-- [[ ✈️ MOVEMENT & FLY SİSTEMİ ]] --
local Tab5 = CreateTab("✈️ Movement")

_G.FlyEnabled = false
_G.FlySpeed = 50

-- Uçma Özelliği Kontrolü
AddToggle(Tab5, "Fly (Uçma Modu)", false, function(v)
    _G.FlyEnabled = v
    
    local torso = LP.Character and (LP.Character:FindFirstChild("LowerTorso") or LP.Character:FindFirstChild("Torso") or LP.Character:FindFirstChild("HumanoidRootPart"))
    if not v and torso then
        -- Uçma kapatıldığında velocity (hız) değerlerini sıfırla ki havada asılı kalmasın
        for _, obj in pairs(torso:GetChildren()) do
            if obj:IsA("BodyVelocity") or obj:IsA("BodyGyro") then
                obj:Destroy()
            end
        end
        if LP.Character:FindFirstChildOfClass("Humanoid") then
            LP.Character:FindFirstChildOfClass("Humanoid").PlatformStand = false
        end
    end
end)

-- Uçma Hızı Ayarı
AddSlider(Tab5, "Uçma Hızı", 10, 250, 50, function(v)
    _G.FlySpeed = v
end)

-- [[ UÇMA MOTORU (RENDERSTEPPED BAĞLANTISI) ]] --
local bv, bg
RunService.RenderStepped:Connect(function()
    if _G.FlyEnabled and LP.Character and LP.Character:FindFirstChildOfClass("Humanoid") then
        local humanoid = LP.Character:FindFirstChildOfClass("Humanoid")
        local torso = LP.Character:FindFirstChild("LowerTorso") or LP.Character:FindFirstChild("Torso") or LP.Character:FindFirstChild("HumanoidRootPart")
        
        if torso then
            humanoid.PlatformStand = true
            
            -- BodyVelocity kontrolü ve oluşturulması
            if not torso:FindFirstChild("WexFlyVelocity") then
                bv = Instance.new("BodyVelocity")
                bv.Name = "WexFlyVelocity"
                bv.maxForce = Vector3.new(1e5, 1e5, 1e5)
                bv.Parent = torso
            else
                bv = torso.WexFlyVelocity
            end
            
            -- BodyGyro kontrolü (Karakterin dik durması ve kameraya dönmesi için)
            if not torso:FindFirstChild("WexFlyGyro") then
                bg = Instance.new("BodyGyro")
                bg.Name = "WexFlyGyro"
                bg.maxTorque = Vector3.new(1e5, 1e5, 1e5)
                bg.cframe = torso.CFrame
                bg.Parent = torso
            else
                bg = torso.WexFlyGyro
            end
            
            -- Yön Hesaplama (Kamera açısına göre)
            local direction = Vector3.new(0, 0, 0)
            
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then
                direction = direction + Camera.CFrame.LookVector
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then
                direction = direction - Camera.CFrame.LookVector
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then
                direction = direction - Camera.CFrame.RightVector
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then
                direction = direction + Camera.CFrame.RightVector
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
                direction = direction + Vector3.new(0, 1, 0)
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
                direction = direction - Vector3.new(0, 1, 0)
            end
            
            -- Hızı ve Bakış Açısını Uygula
            bv.velocity = direction.Unit * _G.FlySpeed
            if direction == Vector3.new(0,0,0) then
                bv.velocity = Vector3.new(0, 0, 0) -- Tuşlara basılmıyorsa havada sabit tut
            end
            bg.cframe = Camera.CFrame
        end
    end
end)

-- [[ 🎯 GELİŞMİŞ AIMBOT AYARLARI & ISKA İHTİMALLİ LEGITBOT SİSTEMİ ]] --

_G.LegitBotEnabled = false
_G.MissChance = 30 -- Varsayılan %30 ıskalama ihtimali
local AimPartsList = {"Head", "UpperTorso", "LeftUpperLeg"}
local AimPartNames = {Head = "Kafa (Head)", UpperTorso = "Gövde (Torso)", LeftUpperLeg = "Bacak (Leg)"}
local partIndex = 1
local currentTargetIsMiss = false -- Mevcut hedef için ıskalama durumu

-- 1. Hedef Bölge Seçici Buton (GUI Elementi)
local PartFrame = Instance.new("Frame")
PartFrame.Size = UDim2.new(1, -5, 0, 35)
PartFrame.BackgroundColor3 = Color3.fromRGB(24, 24, 30)
PartFrame.Parent = Tab1
Instance.new("UICorner", PartFrame).CornerRadius = UDim.new(0, 5)

local PartLabel = Instance.new("TextLabel")
PartLabel.Size = UDim2.new(0.5, 0, 1, 0)
PartLabel.Position = UDim2.new(0, 10, 0, 0)
PartLabel.BackgroundTransparency = 1
PartLabel.Text = "Aimbot Hedef Bölgesi"
PartLabel.TextColor3 = Color3.fromRGB(230, 230, 230)
PartLabel.Font = Enum.Font.Gotham
PartLabel.TextSize = 13
PartLabel.TextXAlignment = Enum.TextXAlignment.Left
PartLabel.Parent = PartFrame

local PartBtn = Instance.new("TextButton")
PartBtn.Size = UDim2.new(0, 120, 0, 22)
PartBtn.Position = UDim2.new(1, -130, 0, 6)
PartBtn.BackgroundColor3 = Color3.fromRGB(45, 45, 55)
PartBtn.Text = AimPartNames[_G.AimPart] or "Kafa (Head)"
PartBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
PartBtn.Font = Enum.Font.GothamBold
PartBtn.TextSize = 11
PartBtn.Parent = PartFrame
Instance.new("UICorner", PartBtn).CornerRadius = UDim.new(0, 4)

PartBtn.MouseButton1Click:Connect(function()
    if _G.LegitBotEnabled then return end 
    partIndex = partIndex + 1
    if partIndex > #AimPartsList then partIndex = 1 end
    _G.AimPart = AimPartsList[partIndex]
    PartBtn.Text = AimPartNames[_G.AimPart]
end)

-- 2. LegitBot Toggle Elementi
AddToggle(Tab1, "LegitBot (Iska İhtimalli)", false, function(v)
    _G.LegitBotEnabled = v
    if v then
        PartBtn.Text = "Legit Aktif"
        PartBtn.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
        PartBtn.TextColor3 = Color3.fromRGB(120, 120, 120)
    else
        partIndex = 1
        _G.AimPart = "Head"
        PartBtn.Text = AimPartNames[_G.AimPart]
        PartBtn.BackgroundColor3 = Color3.fromRGB(45, 45, 55)
        PartBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    end
end)

-- 3. Iska İhtimali Slider Ayarı (Combat Sekmesine Eklenir)
AddSlider(Tab1, "Iska (Miss) İhtimali %", 0, 100, 30, function(v)
    _G.MissChance = v
end)

-- Sağ Tıka basıldığında o anki kilitlenme için ıskalama şansını hesaplar
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.UserInputType == Enum.UserInputType.MouseButton2 then
        if _G.LegitBotEnabled then
            -- Şans hesaplama
            local chance = math.random(1, 100)
            if chance <= _G.MissChance then
                currentTargetIsMiss = true -- Bu sağ tık basılı tutma boyunca ıskalayacak
            else
                currentTargetIsMiss = false -- İsabet edecek
            end
            
            -- Doğal görünüm için kemiği de rastgele karıştır
            if math.random(1, 10) <= 4 then
                _G.AimPart = "Head"
            else
                _G.AimPart = "UpperTorso"
            end
        else
            currentTargetIsMiss = false
        end
    end
end)

-- [[ 🌪️ GELİŞMİŞ HAREKET VE LOKAL MODLAR ]] --

_G.NoclipEnabled = false
_G.WexSpecial = false
local SpecialTarget = nil

-- Smoothness Ayarını Combat Sekmesine Ekleme
AddSlider(Tab1, "Aimbot Sertliği (1=Yumuşak, 10=Sert)", 1, 10, 5, function(v)
    _G.AimbotSmoothness = v / 10
end)

-- Noclip Özelliğini Movement Sekmesine Ekleme
AddToggle(Tab5, "Noclip (Duvarlardan Geçme)", false, function(v)
    _G.NoclipEnabled = v
end)

-- Noclip Motoru
RunService.Stepped:Connect(function()
    if _G.NoclipEnabled and LP.Character then
        for _, part in pairs(LP.Character:GetDescendants()) do
            if part:IsA("BasePart") and part.CanCollide then
                part.CanCollide = false
            end
        end
    end
end)

-- Wex's Special Aktivasyon Fonksiyonu
local function ToggleWexSpecial(state)
    _G.WexSpecial = state
    if not state then
        SpecialTarget = nil
        if LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") then
            local hrp = LP.Character.HumanoidRootPart
            if hrp:FindFirstChild("WexSpecialVelocity") then hrp.WexSpecialVelocity:Destroy() end
        end
    end
end

AddToggle(Tab5, "Wex's Special (Ctrl + C)", false, function(v)
    ToggleWexSpecial(v)
end)

-- Ctrl + C Kısayol Tuşu
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) and input.KeyCode == Enum.KeyCode.C then
        local newState = not _G.WexSpecial
        ToggleWexSpecial(newState)
        if activeToggles["Wex's Special (Ctrl + C)"] then
            activeToggles["Wex's Special (Ctrl + C)"].SetState(newState)
        end
    end
end)

-- [[ ÖZELLEŞTİRİLMİŞ ENTEGRE ANA MOTOR ]] --
RunService.RenderStepped:Connect(function()
    -- Wex's Special Mantığı
    if _G.WexSpecial and LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") then
        local myHrp = LP.Character.HumanoidRootPart
        
        if not SpecialTarget or not SpecialTarget.Character or not SpecialTarget.Character:FindFirstChild("HumanoidRootPart") or (SpecialTarget.Character:FindFirstChildOfClass("Humanoid") and SpecialTarget.Character:FindFirstChildOfClass("Humanoid").Health <= 0) then
            SpecialTarget = GetClosestPlayer()
        end
        
        if SpecialTarget and SpecialTarget.Character and SpecialTarget.Character:FindFirstChild("HumanoidRootPart") then
            local enemyHrp = SpecialTarget.Character.HumanoidRootPart
            myHrp.CFrame = enemyHrp.CFrame * CFrame.new(0, 15, 0)
            
            if not myHrp:FindFirstChild("WexSpecialVelocity") then
                local bv = Instance.new("BodyVelocity")
                bv.Name = "WexSpecialVelocity"
                bv.maxForce = Vector3.new(1e5, 1e5, 1e5)
                bv.velocity = Vector3.new(0, 0, 0)
                bv.Parent = myHrp
            end
            
            local aimTargetPart = SpecialTarget.Character:FindFirstChild(_G.AimPart)
            if aimTargetPart then
                Camera.CFrame = CFrame.new(Camera.CFrame.Position, aimTargetPart.Position)
            end
        end
    end

    -- Yenilenen Iska Mantıklı Aimbot Motoru
    if _G.AimbotEnabled and UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
        local target = GetClosestPlayer()
        if target and target.Character then
            local targetPart = target.Character:FindFirstChild(_G.AimPart)
            if targetPart then
                local targetPos = Camera:WorldToViewportPoint(targetPart.Position)
                local mousePos = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
                
                -- Eğer o anki kilitlenme için ISKA durumu aktifse, hedef pozisyonuna sapma (offset) ekle
                if _G.LegitBotEnabled and currentTargetIsMiss then
                    -- Karakterin 4-7 birim sağına/soluna/yukarısına doğru nişangahı saptırır
                    local offsetVector = Vector2.new(math.random(-45, 45), math.random(-45, 45))
                    targetPos = Vector2.new(targetPos.X + offsetVector.X, targetPos.Y + offsetVector.Y)
                end
                
                mousemoverel((targetPos.X - mousePos.X) * _G.AimbotSmoothness, (targetPos.Y - mousePos.Y) * _G.AimbotSmoothness)
            end
        end
    end
end)
